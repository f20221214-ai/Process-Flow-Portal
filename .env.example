# =============================================================================
# DATABASE — pick ONE mode
# =============================================================================
#
# EMBEDDED (default, no pgAdmin password issues):
#   pnpm env:restore-embedded
#   pnpm dev:db          # terminal 1 — starts Postgres on port 5434
#   pnpm db:schema       # first time only
#   pgAdmin: host 127.0.0.1, port 5434, db arc_portal, user postgres, password postgres
#   Role field: empty    Service field: empty
#
# SYSTEM (your installed PostgreSQL — port 5432, use YOUR install password):
#   pnpm db:migrate-pgadmin
#   pgAdmin: host 127.0.0.1, port 5432, db arc_portal, user postgres, password YOUR_PASSWORD
#   Role field: empty    Service field: empty
#
# Restore embedded if system mode causes problems:
#   pnpm env:restore-embedded
# =============================================================================

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5434/arc_portal
EMBEDDED_PG_PORT=5434
PORT=5173
API_URL=http://localhost:8080
BASE_PATH=/
NODE_ENV=development
LOG_LEVEL=info
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=your-openai-api-key
LEANIX_WORKSPACE=your-workspace-name
LEANIX_API_TOKEN=your-leanix-api-token
